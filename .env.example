# Cypher — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── PostgreSQL (local dev) ────────────────────────────────────────────────────
POSTGRES_USER=cypher
POSTGRES_PASSWORD=cypher
POSTGRES_DB=cypher

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cypher:cypher@postgres:5432/cypher
REDIS_URL=redis://redis:6379/0

# Rate limiting (requests per minute per agent key or IP)
RATE_LIMIT_PER_MINUTE=120

# CORS allowed origins (comma-separated, * for all)
CORS_ORIGINS=*

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_ID=agent-01

# Comma-separated host:port pairs to probe
TARGETS=google.com:443,8.8.8.8:53

# Backend URL reachable from inside the agent container
BACKEND_URL=http://backend:8000

# Probe interval in seconds
PROBE_INTERVAL=30

# TCP connection timeout in seconds
PROBE_TIMEOUT=5

# Agent enrollment key credentials (obtained from the Agents page in the dashboard)
AGENT_KEY_ID=
AGENT_KEY_SECRET=

# ── Notifications (all optional — leave blank to disable) ─────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
GENERIC_WEBHOOK_URL=
