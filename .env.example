# Cypher — Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
# All variables have safe defaults for local development.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=cypher
POSTGRES_PASSWORD=cypher
POSTGRES_DB=cypher

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cypher:cypher@postgres:5432/cypher
REDIS_URL=redis://redis:6379/0

# Optional — Telegram notifications (leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_ID=agent-01

# Comma-separated host:port pairs to probe
TARGETS=google.com:443,8.8.8.8:53

# Backend URL reachable from inside the agent container
BACKEND_URL=http://backend:8000

# Seconds between probe runs
PROBE_INTERVAL=30

# TCP connection timeout per probe in seconds
PROBE_TIMEOUT=5
